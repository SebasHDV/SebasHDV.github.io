---
// ZoomScroll.astro
// Fixed full-screen background animation driven by page scroll.
// Items are abstract geometric symbols — purely decorative, no text.

const symbols = [
  "○","·","×","◆","+","◦","▲","—","∘","◇",
  "○","·","×","◆","+","◦","▲","—","∘","◇",
  "○","·","×","◆","+","◦","▲","—","∘","◇",
  "○","·","×","◆","+","◦","▲","—","∘","◇",
  "○","·","×","◆","+","◦","▲","—","∘","◇",
];
---

<div class="zoom-bg" aria-hidden="true">
  <div class="zoom-grid">
    {symbols.map((s) => <span class="zoom-item">{s}</span>)}
  </div>
</div>

<!-- Ensure page content stacks above the fixed background -->
<style is:global>
  header.sw-header,
  main,
  footer {
    position: relative;
    z-index: 1;
  }
</style>

<style>
  .zoom-bg {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    overflow: hidden;
  }

  @keyframes zoom-in {
    0%   { transform: translateZ(-1000px); opacity: 0;   filter: blur(6px); }
    50%  { transform: translateZ(0px);     opacity: 1;   filter: blur(0px);  }
    100% { transform: translateZ(1000px);  opacity: 0;   filter: blur(6px); }
  }

  .zoom-grid {
    width: 100%;
    height: 100svh;
    perspective: 1000px;
    transform-style: preserve-3d;
    display: grid;
    grid: repeat(4, 25dvh) / repeat(4, 25dvw);
    place-items: center;
    overflow: clip;
  }

  .zoom-item {
    transform-style: preserve-3d;
    font-size: 3.5vmin;
    font-weight: 200;
    color: var(--accent, #3B82F6);
    opacity: 0;
    text-align: center;
    user-select: none;
  }

  @supports (animation-timeline: scroll()) {
    @media (prefers-reduced-motion: no-preference) {
      .zoom-item {
        animation: zoom-in linear both;
        animation-timeline: scroll(root block);
        will-change: transform, opacity, filter;
      }

      .zoom-item:nth-of-type(1)  { grid-area: 1/1; animation-range: 40% 50% }
      .zoom-item:nth-of-type(2)  { grid-area: 1/2; animation-range: 20% 30% }
      .zoom-item:nth-of-type(3)  { grid-area: 1/3; animation-range: 52% 62% }
      .zoom-item:nth-of-type(4)  { grid-area: 1/4; animation-range: 50% 60% }
      .zoom-item:nth-of-type(5)  { grid-area: 2/1; animation-range: 45% 55% }
      .zoom-item:nth-of-type(6)  { grid-area: 2/2; animation-range: 10% 20% }
      .zoom-item:nth-of-type(7)  { grid-area: 2/3; animation-range: 90% 100% }
      .zoom-item:nth-of-type(8)  { grid-area: 2/4; animation-range: 30% 40% }
      .zoom-item:nth-of-type(9)  { grid-area: 3/1; animation-range: 80% 90% }
      .zoom-item:nth-of-type(10) { grid-area: 3/2; animation-range: 70% 80% }
      .zoom-item:nth-of-type(11) { grid-area: 3/3; animation-range: 5% 25% }
      .zoom-item:nth-of-type(12) { grid-area: 3/4; animation-range: 52% 62% }
      .zoom-item:nth-of-type(13) { grid-area: 4/1; animation-range: 15% 25% }
      .zoom-item:nth-of-type(14) { grid-area: 4/2; animation-range: 7% 17% }
      .zoom-item:nth-of-type(15) { grid-area: 4/3; animation-range: 75% 85% }
      .zoom-item:nth-of-type(16) { grid-area: 4/4; animation-range: 3% 13% }
      .zoom-item:nth-of-type(17) { grid-area: 2/1; animation-range: 87% 97% }
      .zoom-item:nth-of-type(18) { grid-area: 2/2; animation-range: 42% 52% }
      .zoom-item:nth-of-type(19) { grid-area: 2/3; animation-range: 57% 67% }
      .zoom-item:nth-of-type(20) { grid-area: 2/4; animation-range: 37% 47% }
      .zoom-item:nth-of-type(21) { grid-area: 3/1; animation-range: 12% 22% }
      .zoom-item:nth-of-type(22) { grid-area: 3/2; animation-range: 8% 18% }
      .zoom-item:nth-of-type(23) { grid-area: 3/3; animation-range: 84% 94% }
      .zoom-item:nth-of-type(24) { grid-area: 3/4; animation-range: 33% 43% }
      .zoom-item:nth-of-type(25) { grid-area: 1/1; animation-range: 48% 58% }
      .zoom-item:nth-of-type(26) { grid-area: 1/2; animation-range: 13% 23% }
      .zoom-item:nth-of-type(27) { grid-area: 1/3; animation-range: 78% 88% }
      .zoom-item:nth-of-type(28) { grid-area: 1/4; animation-range: 62% 72% }
      .zoom-item:nth-of-type(29) { grid-area: 4/1; animation-range: 31% 41% }
      .zoom-item:nth-of-type(30) { grid-area: 4/2; animation-range: 8% 18% }
      .zoom-item:nth-of-type(31) { grid-area: 4/3; animation-range: 4% 14% }
      .zoom-item:nth-of-type(32) { grid-area: 4/4; animation-range: 74% 84% }
      .zoom-item:nth-of-type(33) { grid-area: 2/1; animation-range: 61% 71% }
      .zoom-item:nth-of-type(34) { grid-area: 2/2; animation-range: 26% 36% }
      .zoom-item:nth-of-type(35) { grid-area: 2/3; animation-range: 63% 73% }
      .zoom-item:nth-of-type(36) { grid-area: 2/4; animation-range: 11% 21% }
      .zoom-item:nth-of-type(37) { grid-area: 3/1; animation-range: 89% 99% }
      .zoom-item:nth-of-type(38) { grid-area: 3/2; animation-range: 33% 43% }
      .zoom-item:nth-of-type(39) { grid-area: 3/3; animation-range: 88% 98% }
      .zoom-item:nth-of-type(40) { grid-area: 3/4; animation-range: 22% 32% }
      .zoom-item:nth-of-type(41) { grid-area: 1/1; animation-range: 16% 26% }
      .zoom-item:nth-of-type(42) { grid-area: 1/2; animation-range: 26% 36% }
      .zoom-item:nth-of-type(43) { grid-area: 1/3; animation-range: 66% 76% }
      .zoom-item:nth-of-type(44) { grid-area: 1/4; animation-range: 3% 13% }
      .zoom-item:nth-of-type(45) { grid-area: 4/1; animation-range: 44% 54% }
      .zoom-item:nth-of-type(46) { grid-area: 4/2; animation-range: 11% 21% }
      .zoom-item:nth-of-type(47) { grid-area: 4/3; animation-range: 23% 33% }
      .zoom-item:nth-of-type(48) { grid-area: 4/4; animation-range: 39% 49% }
      .zoom-item:nth-of-type(49) { grid-area: 3/1; animation-range: 59% 69% }
      .zoom-item:nth-of-type(50) { grid-area: 3/2; animation-range: 6% 16% }
    }
  }
</style>
